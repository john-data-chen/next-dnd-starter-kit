{
  "name": "next-dnd-starter-kit",
  "version": "1.0.0",
  "private": true,
  "author": {
    "name": "john.chen",
    "url": "https://github.com/john-data-chen/next-dnd-starter-kit"
  },
  "scripts": {
    "build": "pnpm typecheck && next build",
    "commit": "git-cz",
    "dev": "next dev",
    "format": "oxfmt --no-error-on-unmatched-pattern --config ./.oxfmtrc.json",
    "init-db": "tsx database/init-db-data.ts",
    "init-db:force": "tsx database/init-db-data.ts --force",
    "lint": "oxlint src --type-aware --fix",
    "playwright": "npx playwright test",
    "prepare": "if [ \"$NODE_ENV\" != \"production\" ]; then husky; fi",
    "start": "next start",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@vercel/analytics": "^2.0.1",
    "better-auth": "^1.6.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "mongoose": "^9.6.2",
    "next": "16.2.6",
    "next-intl": "^4.11.1",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "postcss": "^8.5.14",
    "radix-ui": "latest",
    "react": "19.2.6",
    "react-day-picker": "^10.0.0",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.75.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@commitlint/cz-commitlint": "^21.0.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "latest",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "commitizen": "^4.3.1",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "{src/!(components)/**/*.{js,jsx,ts,tsx,css,scss},src/components/!(ui)/**/*.{js,jsx,ts,tsx,css,scss}}": [
      "oxfmt --no-error-on-unmatched-pattern --config ./.oxfmtrc.json"
    ],
    "{src/!(components)/**/*.{js,jsx,ts,tsx},src/components/!(ui)/**/*.{js,jsx,ts,tsx}}": [
      "oxlint --type-aware --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "packageManager": "pnpm@11.0.9",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ],
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/engines",
      "@swc/core",
      "@tailwindcss/oxide",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}